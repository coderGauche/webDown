{
  "name": "sitecapsule",
  "version": "0.1.0",
  "description": "A local-first Chrome extension for archiving public webpages.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "icons:generate": "node scripts/generate-icons.mjs",
    "zip": "wxt zip",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write 'entrypoints/**/*.{ts,tsx,css,html}' 'src/**/*.{ts,tsx}' 'scripts/**/*.{js,mjs}' 'tests/**/*.{ts,tsx,html}' 'wxt.config.ts' 'vitest.config.ts' 'eslint.config.js' 'tsconfig.json' 'package.json'",
    "format:check": "prettier --check 'entrypoints/**/*.{ts,tsx,css,html}' 'src/**/*.{ts,tsx}' 'scripts/**/*.{js,mjs}' 'tests/**/*.{ts,tsx,html}' 'wxt.config.ts' 'vitest.config.ts' 'eslint.config.js' 'tsconfig.json' 'package.json'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "dexie": "4.4.4",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "eslint": "10.7.0",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "happy-dom": "20.11.1",
    "prettier": "3.9.6",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
